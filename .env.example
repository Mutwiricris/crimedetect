# Copy this file to .env and fill in your values.
# The app reads from environment variables – no .env auto-load in production.
# Use python-dotenv locally: pip install python-dotenv

# ── Security ──────────────────────────────────────────────────────────────────
# Set a strong random key in production. Must match X-API-Key header on every request.
API_KEY=devkey

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for your Laravel app.
# Use * for dev only.
ALLOWED_ORIGINS=*

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ── Paths (optional overrides) ────────────────────────────────────────────────
# MODELS_DIR=models
# DATASETS_DIR=Datasets
